# ── Required ──────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string (replace with your actual URI)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/pragati?retryWrites=true&w=majority

# Strong random secret — generate with: openssl rand -base64 48
JWT_SECRET=replace-me-with-a-long-random-secret

# ── Admin (single super-user) ────────────────────────────────────────────────
# Email that gets the 'admin' role automatically on login / registration.
# Admin sees every team, project, and user, and can reset anyone's password
# from the People page. Leave blank in dev if you don't want one.
ADMIN_EMAIL=

# ── First-run bootstrap (browser-only setup) ─────────────────────────────────
# When set to a long random string (>= 16 chars), the /bootstrap page becomes
# operative. Paste this token there, pick an admin email + password, and the
# account is provisioned + seed data is wiped — all without shell access.
# UNSET the variable + redeploy as soon as you're done; the endpoint then 404s.
# ADMIN_BOOTSTRAP_TOKEN=

# ── QA Copilot (optional) ─────────────────────────────────────────────────────
# Used only by the conversational Copilot. The QA Triage Assistant is
# rule-based and never uses an LLM — see CLAUDE.md.
GEMINI_API_KEY=

# ── Redis cache (optional) ────────────────────────────────────────────────────
# Upstash Redis REST credentials. When BOTH are set, hot read-only aggregations
# (e.g. the lead dashboard rollup) are served read-through from Redis with a
# short TTL; when either is missing the cache layer is a transparent no-op and
# every read goes straight to MongoDB (see src/lib/cache.ts). Never caches GxP
# records, audit entries, e-signatures, or the deterministic triage path.
# Get these from the Upstash console → your database → "REST API".
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Development only (remove in production) ───────────────────────────────────
# Set true to run an embedded in-memory MongoDB instead of Atlas.
# USE_IN_MEMORY_MONGO=true
