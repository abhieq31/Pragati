# ── Required ──────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string (replace with your actual URI)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/pragati?retryWrites=true&w=majority

# Strong random secret — generate with: openssl rand -base64 48
JWT_SECRET=replace-me-with-a-long-random-secret

# ── Email (password reset) ────────────────────────────────────────────────────
# Required for the /forgot-password flow to deliver reset links.
SMTP_HOST=smtp.yourprovider.com
SMTP_USER=your@email.com
SMTP_PASS=your-smtp-password
APP_URL=http://localhost:3000

# ── PM bootstrap ──────────────────────────────────────────────────────────────
# Comma-separated emails that automatically get PM role on registration.
# Add your email and any other managers here BEFORE they register.
PM_EMAILS=

# ── QA Copilot (optional) ─────────────────────────────────────────────────────
# Used only by the conversational Copilot. The QA Triage Assistant is
# rule-based and never uses an LLM — see CLAUDE.md.
GEMINI_API_KEY=

# ── Development only (remove in production) ───────────────────────────────────
# Set true to run an embedded in-memory MongoDB instead of Atlas.
# USE_IN_MEMORY_MONGO=true
